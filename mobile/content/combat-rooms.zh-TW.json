{
  "type": "combat",
  "zone": "THRESHOLD OF THE UNNAMED",
  "rooms": [
    {
      "template": "ambush",
      "variations": [
        {
          "id": "ambush_1",
          "narrative": "這房間看似空無一物。水面靜止，空氣靜止。然後你看見了——無物移動之處，水面泛起漣漪。正在升起。它一直在下面等著。",
          "enemy": "The Drowned"
        },
        {
          "id": "ambush_2",
          "narrative": "你先聽見，半秒之後才看見。濕黏的喀噠聲敲在石上。在你上方。攀在天花板上。落下來了。就是現在。",
          "enemy": "Pale Crawler"
        },
        {
          "id": "ambush_3",
          "narrative": "你的影子動得不對勁。你察覺得太遲——空洞者已在你的輪廓之內，正穿過它伸出手，朝你伸來。",
          "enemy": "The Hollow"
        },
        {
          "id": "ambush_4",
          "narrative": "你跨過的那具屍骸沒有死。它抓住你的腳踝。那握力遠比任何腐爛之物該有的更強。它張開嘴。沒有聲音。",
          "enemy": "Bloated One"
        },
        {
          "id": "ambush_5",
          "narrative": "視野邊緣一閃。你轉頭。什麼都沒有。轉回來。它在那裡。就在眼前。它一直就在眼前。",
          "enemy": "Flickering Shade"
        }
      ]
    },
    {
      "template": "confrontation",
      "variations": [
        {
          "id": "confrontation_1",
          "narrative": "它擋在你的路上。等著。頭顱帶著耐心的飢餓追蹤你的動作。無路可繞。只能穿過去。",
          "enemy": "The Drowned"
        },
        {
          "id": "confrontation_2",
          "narrative": "那東西堵住了門。它沒有進攻。沒有移動。它只是……在那裡。估量著。無論它做出什麼決定，你都不會喜歡。",
          "enemy": "Forgotten Guardian"
        },
        {
          "id": "confrontation_3",
          "narrative": "它跪在祭壇前，以刺痛你思緒的頻率誦唸。它知道你在這裡。這誦唸是為你而作。一份邀請，或一紙死刑。",
          "enemy": "Hollow Clergy"
        },
        {
          "id": "confrontation_4",
          "narrative": "騎士舉起鏽蝕的刀刃致意。光榮的決鬥。至死方休。它期待你打得漂亮。無論如何，它都會失望。",
          "enemy": "Carrion Knight"
        },
        {
          "id": "confrontation_5",
          "narrative": "它從水中升起，兩倍於你的身高，滴淌著黑暗。有一瞬間，它幾乎像人。然後它張開嘴。然後它有了太多張嘴。",
          "enemy": "Mother of Tides"
        }
      ]
    },
    {
      "template": "territorial",
      "variations": [
        {
          "id": "territorial_1",
          "narrative": "骨頭堆疊於此。經過排列。這是巢穴。而你剛剛吵醒了住在裡面的東西。它不想殺你。它想要你離開。太遲了。",
          "enemy": "Pale Crawler"
        },
        {
          "id": "territorial_2",
          "narrative": "這裡的水更暖。有什麼龐然大物一直歇在水下。那東西正在升起，因被打擾而憤怒。這是它的水池。你是擅闖者。",
          "enemy": "Tideborn"
        },
        {
          "id": "territorial_3",
          "narrative": "牆上滿是抓痕。地盤。那生物從一道你未曾留意的裂縫中現身，守衛它宣示過的土地。每一寸都曾讓它付出代價。",
          "enemy": "The Hunched"
        },
        {
          "id": "territorial_4",
          "narrative": "這裡曾是神龕。如今是巢穴。奪下它的那東西不在此膜拜——它在此稱王。而你剛剛不請自來，闖進了它的王庭。",
          "enemy": "Hollow Clergy"
        },
        {
          "id": "territorial_5",
          "narrative": "鎖鏈在黑暗中作響。受縛者佔據了這條通道。它不會放你過去。它不會放任何人過去。它的孤獨具有攻擊性。",
          "enemy": "The Bound"
        }
      ]
    },
    {
      "template": "pursuit",
      "variations": [
        {
          "id": "pursuit_1",
          "narrative": "你已經聽了它三個房間。一次比一次近。一次比一次快。逃是沒用的。該停下來了。",
          "enemy": "The Hunched"
        },
        {
          "id": "pursuit_2",
          "narrative": "從樓梯口它就一路跟著。耐心。不休不止。你跑不過它——它熟悉這些隧道。這些隧道是它挖的。站定，面對它。",
          "enemy": "The Bound"
        },
        {
          "id": "pursuit_3",
          "narrative": "身後的水聲停了。這更糟。這代表它不再追了。這代表它已經到了。",
          "enemy": "The Drowned"
        },
        {
          "id": "pursuit_4",
          "narrative": "喀噠聲就在你背後。你能感覺到它的呼吸——如果那算呼吸——貼在你的頸上。轉身。你必須轉身。你不想轉身。",
          "enemy": "Pale Crawler"
        },
        {
          "id": "pursuit_5",
          "narrative": "每次回頭，它都更近一些。你看著的時候它從不移動。你不可能永遠看著。眼睛在灼痛。一眨眼，就結束了。",
          "enemy": "The Hollow"
        }
      ]
    },
    {
      "template": "swarm",
      "variations": [
        {
          "id": "swarm_1",
          "narrative": "一隻不成威脅。但不止一隻。牠們從牆縫、從地板的空隙裡湧出。數十隻。還在來。永遠還有更多。",
          "enemy": "Pale Crawler Swarm"
        },
        {
          "id": "swarm_2",
          "narrative": "水裡滿是牠們。細小、攫取的東西。單獨時不值一提。聚在一起，便是一股由牙齒與飢餓匯成的湍流。水位隨牠們的軀體上漲。",
          "enemy": "Tideborn"
        },
        {
          "id": "swarm_3",
          "narrative": "手。只有手。從四面八方冒出——地板、牆壁、天花板。攫取，拉扯，拖拽。沒有軀體可以對付。只有手。",
          "enemy": "Bone Weavers"
        },
        {
          "id": "swarm_4",
          "narrative": "灰燼之子聚攏了。過去牠們只是看著，那樣就夠了。如今牠們想要更多。牠們步步進逼。空氣越來越稀薄。牠們不是在攻擊——是在窒殺。",
          "enemy": "Ash Children"
        },
        {
          "id": "swarm_5",
          "narrative": "回聲空殼找到了彼此。一支由竊來的遺言組成的合唱，同進同退，同時伸手。「救我救我救我」——同一句哀求，出自十幾副毀壞的喉嚨。",
          "enemy": "Echo Husks"
        }
      ]
    },
    {
      "template": "feeding",
      "variations": [
        {
          "id": "feeding_1",
          "narrative": "它在吃什麼東西。聲音濕黏，有條不紊。它還沒看見你。你可以溜過去。你可以先下手。反正它很快就會吃完。",
          "enemy": "The Hunched"
        },
        {
          "id": "feeding_2",
          "narrative": "溺亡者找到了一具屍骸。它不是在吃——是在……吸收。越變越大。越變越強。你每等一刻，它就更危險一分。",
          "enemy": "Bloated One"
        },
        {
          "id": "feeding_3",
          "narrative": "那生物伏在一個曾經是人的東西上。它抬起頭。滿嘴食物。被打擾似乎沒讓它不快。它似乎心存感激。又有吃的來了。",
          "enemy": "Pale Crawler"
        },
        {
          "id": "feeding_4",
          "narrative": "慟哭者找到了可供啃食的悲傷。另一名玩家的屍骸，遺言猶新。它啜飲他們的哀慟。它轉向你。你的哀慟聞起來更為豐盈。",
          "enemy": "The Weeping"
        },
        {
          "id": "feeding_5",
          "narrative": "它坐在骨堆之間，把骨頭一根根敲開，啜飲裡面的東西。老骨頭。古老的骨頭。它已在此進食數百年。你是很久以來第一件新鮮的東西。",
          "enemy": "The Hunched"
        }
      ]
    },
    {
      "template": "guardian",
      "variations": [
        {
          "id": "guardian_1",
          "narrative": "它立於門前。它一直立於此門之前。它會死在此門之前。你也一樣——如果你想要門後的東西。",
          "enemy": "Forgotten Guardian"
        },
        {
          "id": "guardian_2",
          "narrative": "彼端的通道藏著重要之物。你感覺得到。擋住你去路的那東西也感覺得到。它被安置於此。它有使命。那使命就是你。",
          "enemy": "Carrion Knight"
        },
        {
          "id": "guardian_3",
          "narrative": "出口就在那裡。二十呎。你與它之間，立著一個為此刻等候至今的東西。你的時刻。它的使命。",
          "enemy": "Hollow Clergy"
        },
        {
          "id": "guardian_4",
          "narrative": "補給就在前方。物資、武器、希望。守著它的那東西不需要其中任何一樣。它只是不想讓你得到。",
          "enemy": "The Bound"
        },
        {
          "id": "guardian_5",
          "narrative": "它守護這座神龕。不是神——神已死。不是供品——供品已腐。它守護的是那個念頭。那份記憶。它會守護它們，不讓你染指。",
          "enemy": "Forgotten Guardian"
        }
      ]
    },
    {
      "template": "arena",
      "variations": [
        {
          "id": "arena_1",
          "narrative": "石室渾圓。光滑。為此而造。你感到有目光落在身上——從何處？對面的那東西不在乎觀眾。只在乎你。",
          "enemy": "Carrion Knight"
        },
        {
          "id": "arena_2",
          "narrative": "層層座席環繞著中央的深坑。座位是空的，存在感卻不是。有什麼在看。有什麼在裁決。坑中的生物等著你下場。",
          "enemy": "The Bound"
        },
        {
          "id": "arena_3",
          "narrative": "一座白骨的圓形劇場。聲學完美無缺——每一聲喘息、每一聲悶哼、每一陣臨死的咯咯聲，都將迴響得優美動聽。會眾正等著開演。",
          "enemy": "The Congregation"
        },
        {
          "id": "arena_4",
          "narrative": "地上畫著一個圓。古老。具有約束之力。一旦踏入，在你們其中一個停止動作之前，誰也不能離開。圓裡的那東西從不停止動作。",
          "enemy": "Flickering Shade"
        },
        {
          "id": "arena_5",
          "narrative": "你踏入時，房間開始重組。牆壁升起。出口封閉。一個空間被造了出來。一座舞台。一座競技場。在某處，有什麼看得津津有味。",
          "enemy": "The Unnamed"
        }
      ]
    },
    {
      "template": "wounded",
      "variations": [
        {
          "id": "wounded_1",
          "narrative": "它在流血。拖著身子。傷不是你造成的——有別人試過。有別人失敗了。它看見你。齜牙咧嘴。恐懼與暴怒，各佔一半。",
          "enemy": "The Drowned"
        },
        {
          "id": "wounded_2",
          "narrative": "它少了一半。剩下的一半仍在運作。仍在狩獵。殘缺，卻未完結。它再沒有什麼可失去的了。這讓它更加危險。",
          "enemy": "Pale Crawler"
        },
        {
          "id": "wounded_3",
          "narrative": "守衛裂了。缺了幾塊。是另一個冒險者幹的。那個冒險者呢？多半死了。但他們削弱了它。完成他們開的頭。",
          "enemy": "Forgotten Guardian"
        },
        {
          "id": "wounded_4",
          "narrative": "它一瘸一拐地朝你走來。殘破，卻未被打垮。每一道傷都讓它更憤怒。每一分痛都讓它更恨你。慈悲不在它能理解的選項之內。",
          "enemy": "The Hunched"
        },
        {
          "id": "wounded_5",
          "narrative": "斷裂的鎖鏈懸在它的手腕上。它逃離了什麼。或者試圖逃離。如今它自由了，帶著傷，滿心惶惑，而你是它看見的第一個東西。真走運。",
          "enemy": "The Bound"
        }
      ]
    }
  ]
}
